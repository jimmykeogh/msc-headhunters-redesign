# Legacy blog catch-all: unmapped root-slug URLs → /blog/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(case-studies|testimonials|industries-and-sectors|images|shared|wp-content)/ [NC]
RewriteCond %{REQUEST_URI} ^/[a-z0-9-]+/?$ [NC]
RewriteRule ^ /blog/ [R=301,L]

# WordPress-era paths that should vanish
RewriteRule ^category/.+$ /blog/ [R=301,L]
RewriteRule ^tag/.+$ /blog/ [R=301,L]
RewriteRule ^author/.+$ /about-msc-headhunters/ [R=301,L]
# Tell Google these WordPress paths are gone for good
RewriteRule ^wp-content/.+$ - [R=410,L]
RewriteRule ^wp-admin/?.*$ - [R=410,L]
RewriteRule ^feed/?$ /blog/ [R=301,L]
