RewriteRule ^testimonials/roland/?$ testimonials/roland.html [L]
RewriteRule ^testimonials/thales/?$ testimonials/thales.html [L]
RewriteRule ^the\-first\-interview/?$ the-first-interview.html [L]
RewriteRule ^testimonials/decal/?$ testimonials/decal.html [L]
RewriteRule ^company\-culture/?$ company-culture.html [L]
RewriteRule ^global\-clients/?$ clients.html [L]
RewriteRule ^fee\-structure/?$ fee-structure.html [L]
RewriteRule ^why\-choose\-us/?$ why-choose-us.html [L]
RewriteRule ^graduate\-tips/?$ graduate-tips.html [L]
RewriteRule ^case\-studies/?$ case-studies.html [L]
RewriteRule ^netherlands/?$ netherlands.html [L]
RewriteRule ^thank\-you/?$ thank-you.html [L]
RewriteRule ^bahrain/?$ bahrain.html [L]
RewriteRule ^germany/?$ germany.html [L]
RewriteRule ^russia/?$ russia.html [L]
RewriteRule ^kuwait/?$ kuwait.html [L]
RewriteRule ^china/?$ china.html [L]
RewriteRule ^saudi/?$ saudi.html [L]
RewriteRule ^qatar/?$ qatar.html [L]
RewriteRule ^oman/?$ oman.html [L]
RewriteRule ^blog/?$ blog.html [L]
RewriteRule ^usa/?$ usa.html [L]
RewriteRule ^uae/?$ uae.html [L]

# Legacy blog catch-all: unmapped root-slug URLs → /blog/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(case-studies|testimonials|industries-and-sectors|images|shared|wp-content)/ [NC]
RewriteCond %{REQUEST_URI} ^/[a-z0-9-]+/?$ [NC]
RewriteRule ^ /blog/ [R=301,L]

# WordPress-era paths that should vanish
RewriteRule ^category/.+$ /blog/ [R=301,L]
RewriteRule ^tag/.+$ /blog/ [R=301,L]
RewriteRule ^author/.+$ /about-msc-headhunters/ [R=301,L]
# Tell Google these WordPress paths are gone for good
RewriteRule ^wp-content/.+$ - [R=410,L]
RewriteRule ^wp-admin/?.*$ - [R=410,L]
RewriteRule ^feed/?$ /blog/ [R=301,L]
