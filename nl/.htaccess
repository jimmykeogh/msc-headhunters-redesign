RewriteEngine On

# ============================================================
# URL PRESERVATION: serve new .html files at original URLs
# Google's index points at these URLs — do not change them.
# ============================================================

# Canonical enforcement: redirect .html direct hits to pretty URL

# Pretty URL rewrites (serve new file at original URL)
RewriteRule ^international\-headhunting\.html$ international.html [L]
RewriteRule ^sectors/manufacturing\.html$ manufacturing-headhunters.html [L]
RewriteRule ^sectors/technology\.html$ technology-headhunters.html [L]
RewriteRule ^sectors/marketing\.html$ marketing-headhunters.html [L]
RewriteRule ^sectors/sectors\.html$ sectors.html [L]
RewriteRule ^sectors/finance\.html$ finance-headhunters.html [L]
RewriteRule ^sectors/medical\.html$ healthcare-headhunters.html [L]
RewriteRule ^privacy_policy\.html$ privacy.html [L]
RewriteRule ^sectors/retail\.html$ retail-headhunters.html [L]
RewriteRule ^sectors/media\.html$ media-headhunters.html [L]

# Blog catch-all for NL
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^blog/.+$ /blog.html [R=301,L]
RewriteRule ^categorie/.+$ /blog.html [R=301,L]
RewriteRule ^tag/.+$ /blog.html [R=301,L]
RewriteRule ^auteur/.+$ /about.html [R=301,L]
