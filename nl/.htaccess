RewriteEngine On

# Existing explicit redirects
RewriteRule ^international-headhunting\.html$ /international.html [R=301,L]
RewriteRule ^sectors/sectors\.html$ /sectors.html [R=301,L]
RewriteRule ^privacy_policy\.html$ /privacy.html [R=301,L]

# Core page redirects (common Dutch slugs)
RewriteRule ^headhunting-diensten/?$ /services.html [R=301,L]
RewriteRule ^over-msc-headhunters/?$ /about.html [R=301,L]
RewriteRule ^internationale-headhunters/?$ /international.html [R=301,L]
RewriteRule ^referenties/?$ /testimonials.html [R=301,L]
RewriteRule ^klanten-referenties/?$ /testimonials.html [R=301,L]
RewriteRule ^honoraria/?$ /fee-structure.html [R=301,L]
RewriteRule ^waarom-msc/?$ /why-choose-us.html [R=301,L]
RewriteRule ^veelgestelde-vragen/?$ /faq.html [R=301,L]
RewriteRule ^privacybeleid/?$ /privacy.html [R=301,L]
RewriteRule ^sectoren/?$ /sectors.html [R=301,L]
RewriteRule ^contact/?$ /contact.html [R=301,L]

# Blog catch-all for 675 old Dutch blog posts
RewriteRule ^blog/.+$ /blog.html [R=301,L]
RewriteRule ^category/.+$ /blog.html [R=301,L]
RewriteRule ^categorie/.+$ /blog.html [R=301,L]
RewriteRule ^tag/.+$ /blog.html [R=301,L]
RewriteRule ^author/.+$ /about.html [R=301,L]
RewriteRule ^auteur/.+$ /about.html [R=301,L]
