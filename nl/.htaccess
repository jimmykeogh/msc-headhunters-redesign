RewriteEngine On

# ============================================================
# URL PRESERVATION: serve new .html files at original URLs
# Google's index points at these URLs — do not change them.
# ============================================================

# Canonical enforcement: redirect new-file .html direct hits to the
# Google-indexed URL. Uses THE_REQUEST so only EXTERNAL requests match —
# internal rewrites (below) won't trigger these and cause loops.
RewriteCond %{THE_REQUEST} \s/+international\.html[\s?] [NC]
RewriteRule ^ /international-headhunting.html [R=301,L]
RewriteCond %{THE_REQUEST} \s/+sectors\.html[\s?] [NC]
RewriteRule ^ /sectors/sectors.html [R=301,L]
RewriteCond %{THE_REQUEST} \s/+privacy\.html[\s?] [NC]
RewriteRule ^ /privacy_policy.html [R=301,L]
RewriteCond %{THE_REQUEST} \s/+finance-headhunters\.html[\s?] [NC]
RewriteRule ^ /sectors/finance.html [R=301,L]
RewriteCond %{THE_REQUEST} \s/+technology-headhunters\.html[\s?] [NC]
RewriteRule ^ /sectors/technology.html [R=301,L]
RewriteCond %{THE_REQUEST} \s/+manufacturing-headhunters\.html[\s?] [NC]
RewriteRule ^ /sectors/manufacturing.html [R=301,L]
RewriteCond %{THE_REQUEST} \s/+marketing-headhunters\.html[\s?] [NC]
RewriteRule ^ /sectors/marketing.html [R=301,L]
RewriteCond %{THE_REQUEST} \s/+media-headhunters\.html[\s?] [NC]
RewriteRule ^ /sectors/media.html [R=301,L]
RewriteCond %{THE_REQUEST} \s/+retail-headhunters\.html[\s?] [NC]
RewriteRule ^ /sectors/retail.html [R=301,L]
RewriteCond %{THE_REQUEST} \s/+healthcare-headhunters\.html[\s?] [NC]
RewriteRule ^ /sectors/medical.html [R=301,L]

# Directory-level redirect: /sectors/ has no index — send to /sectors/sectors.html
RewriteRule ^sectors/?$ /sectors/sectors.html [R=301,L]

# Pretty URL rewrites (serve new file at original URL)
RewriteRule ^international\-headhunting\.html$ international.html [L]
RewriteRule ^sectors/manufacturing\.html$ manufacturing-headhunters.html [L]
RewriteRule ^sectors/technology\.html$ technology-headhunters.html [L]
RewriteRule ^sectors/marketing\.html$ marketing-headhunters.html [L]
RewriteRule ^sectors/sectors\.html$ sectors.html [L]
RewriteRule ^sectors/finance\.html$ finance-headhunters.html [L]
RewriteRule ^sectors/medical\.html$ healthcare-headhunters.html [L]
RewriteRule ^privacy_policy\.html$ privacy.html [L]
RewriteRule ^sectors/retail\.html$ retail-headhunters.html [L]
RewriteRule ^sectors/media\.html$ media-headhunters.html [L]

# Blog catch-all for NL
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^blog/.+$ /blog.html [R=301,L]
RewriteRule ^categorie/.+$ /blog.html [R=301,L]
RewriteRule ^tag/.+$ /blog.html [R=301,L]
RewriteRule ^auteur/.+$ /about.html [R=301,L]
